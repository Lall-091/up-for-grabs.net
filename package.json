{
  "name": "up-for-grabs.net",
  "version": "1.0.0",
  "main": "index.js",
  "description": "Tooling for up-for-grabs.net development",
  "repository": "https://github.com/up-for-grabs/up-for-grabs.net",
  "license": "MIT",
  "scripts": {
    "check": "tsc",
    "eslint-check": "eslint --print-config javascripts/main.js | eslint-config-prettier-check",
    "lint": "eslint javascripts/*.js tests/**/*.js",
    "lint-fix": "eslint --fix javascripts/*.js tests/**/*.js",
    "lint-new": "eslint -c eslint-new.config.mjs src/**/*.astro src/**/*.vue *.mjs",
    "lint-new-fix": "eslint  -c eslint-new.config.mjs --fix src/**/*.astro src/**/*.vue *.mjs",
    "prettier": "prettier --check .",
    "prettier-fix": "prettier --write .",
    "test": "jest --config ./jest.config.js --verbose --coverage",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "dependencies": {
    "amdefine": ">=0.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/vue": "^5.1.4",
    "@babel/core": "^7.28.6",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25",
    "@types/showdown": "^2.0.6",
    "@types/underscore": "^1.13.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "astro": "^5.16.15",
    "babel-jest": "^30.2.0",
    "date-fns": "^4.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-jest": "^29.12.1",
    "eslint-plugin-vue": "^10.6.2",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-fetch-mock": "^3.0.3",
    "jest-localstorage-mock": "^2.4.26",
    "prettier": "^3.8.0",
    "promise-polyfill": "^8.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0",
    "underscore": "^1.13.7",
    "vue": "^3.5.26",
    "whatwg-fetch": "^3.6.20"
  }
}
